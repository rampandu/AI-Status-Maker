<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <!-- Home -->
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.statusmaker.videoapp.ui.home.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_homeFragment_to_templateListFragment"
            app:destination="@id/templateListFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left" />
        <action
            android:id="@+id/action_homeFragment_to_premiumFragment"
            app:destination="@id/premiumFragment" />
    </fragment>

    <!-- Template List -->
    <fragment
        android:id="@+id/templateListFragment"
        android:name="com.statusmaker.videoapp.ui.template.TemplateListFragment"
        android:label="Templates"
        tools:layout="@layout/fragment_template_list">
        <argument
            android:name="category"
            android:defaultValue="@null"
            app:argType="string"
            app:nullable="true" />
        <action
            android:id="@+id/action_templateListFragment_to_editorFragment"
            app:destination="@id/editorFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left" />
    </fragment>

    <!-- Editor -->
    <fragment
        android:id="@+id/editorFragment"
        android:name="com.statusmaker.videoapp.ui.editor.EditorFragment"
        android:label="Editor"
        tools:layout="@layout/fragment_editor">
        <argument
            android:name="templateId"
            app:argType="string" />
        <action
            android:id="@+id/action_editorFragment_to_previewFragment"
            app:destination="@id/previewFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left" />
    </fragment>

    <!-- Preview -->
    <fragment
        android:id="@+id/previewFragment"
        android:name="com.statusmaker.videoapp.ui.preview.PreviewFragment"
        android:label="Preview"
        tools:layout="@layout/fragment_preview">
        <argument android:name="templateId"      app:argType="string" />
        <argument android:name="personName"      app:argType="string" />
        <argument android:name="villageName"     app:argType="string" />
        <argument android:name="businessName"    app:argType="string" />
        <argument android:name="festivalName"    app:argType="string" />
        <argument android:name="customMessage"   app:argType="string" />
        <argument android:name="photoUri"        app:argType="string" />
        <argument android:name="musicStyleOrdinal" app:argType="integer" android:defaultValue="0" />
    </fragment>

    <!-- Premium -->
    <fragment
        android:id="@+id/premiumFragment"
        android:name="com.statusmaker.videoapp.ui.premium.PremiumFragment"
        android:label="Premium"
        tools:layout="@layout/fragment_premium" />

</navigation>
