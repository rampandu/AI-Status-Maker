<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="⭐ Premium"
            android:textColor="@color/accent_gold"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Unlock unlimited video creation\nNo watermarks • All templates • No ads"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginBottom="24dp"/>

        <!-- Benefits Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/surface_dark"
            app:cardCornerRadius="16dp"
            app:strokeColor="@color/accent_gold"
            app:strokeWidth="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="✅  Remove watermark permanently"
                    android:textColor="@color/text_primary" android:textSize="14sp" android:layout_marginBottom="8dp"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="✅  No ads before export"
                    android:textColor="@color/text_primary" android:textSize="14sp" android:layout_marginBottom="8dp"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="✅  Access all premium templates"
                    android:textColor="@color/text_primary" android:textSize="14sp" android:layout_marginBottom="8dp"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="✅  Unlimited video exports"
                    android:textColor="@color/text_primary" android:textSize="14sp" android:layout_marginBottom="8dp"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="✅  Priority support"
                    android:textColor="@color/text_primary" android:textSize="14sp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Monthly Plan -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMonthlyPlan"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="@color/accent_gold"
            android:text="Monthly Premium – ₹99/month"
            android:textColor="@color/bg_dark"
            android:textStyle="bold"
            app:cornerRadius="12dp" />

        <!-- Annual Plan -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/accent_gold"
            app:cardCornerRadius="12dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#CC000000"
                    android:gravity="center"
                    android:padding="3dp"
                    android:text="🔥 BEST VALUE – SAVE 50%"
                    android:textColor="@color/accent_gold"
                    android:textSize="11sp"
                    android:textStyle="bold"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAnnualPlan"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:backgroundTint="@color/accent_gold"
                    android:text="Annual Premium – ₹599/year"
                    android:textColor="@color/bg_dark"
                    android:textStyle="bold"
                    app:cornerRadius="0dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- One-time Watermark Removal -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemoveWatermark"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp"
            android:text="Remove Watermark Only – ₹49 (one-time)"
            android:textColor="@color/text_primary"
            app:cornerRadius="12dp"
            app:strokeColor="@color/text_secondary" />

        <!-- Success message (hidden) -->
        <LinearLayout
            android:id="@+id/premiumSuccessGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎉 Premium Activated! Enjoy!"
                android:textColor="#4CAF50"
                android:textSize="18sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Restore Purchases -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRestorePurchases"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Restore Purchases"
            android:textColor="@color/text_secondary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:text="Subscriptions auto-renew. Cancel anytime in Play Store.\nPayment charged to Google Play account."
            android:textColor="@color/text_secondary"
            android:textSize="11sp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
